# --- Frontend (Vercel) ---
# Your deployed backend URL on Render (e.g., https://my-music-app-api.onrender.com)
VITE_API_URL=http://localhost:5000

# Jamendo API Client ID (Used by frontend)
VITE_JAMENDO_CLIENT_ID=your_jamendo_client_id_here

# --- Backend (Render) ---
# Port for the server (Render sets this automatically)
PORT=5000

# CORS Allowed Origin (Your deployed frontend URL on Vercel)
FRONTEND_URL=http://localhost:5173

# API Keys (If used by backend)
# YOUTUBE_API_KEY=your_youtube_api_key_here
# JAMENDO_CLIENT_ID=your_jamendo_client_id_here
# MONGODB_URI=your_mongodb_uri_here
